# Copy to project-root `.env` and `backend/.env` (same content). Never commit `.env`.
# Docker Compose reads the root `.env` only for ${POSTGRES_*} substitution in docker-compose.yml.

POSTGRES_USER=eventmanager
POSTGRES_PASSWORD=eventmanager
POSTGRES_DB=eventmanager

# Host tools (Alembic, uvicorn on host, pytest): Postgres published on host port 5433
DATABASE_URL=postgresql+psycopg2://eventmanager:eventmanager@127.0.0.1:5433/eventmanager
